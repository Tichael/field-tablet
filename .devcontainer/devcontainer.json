{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [5173, 5037],
  "portsAttributes": {
    "5173": {
      "label": "React Dev Server (Vite)",
      "onAutoForward": "notify"
    },
    "5037": {
      "label": "ADB Server",
      "onAutoForward": "ignore"
    }
  },
  "containerEnv": {
    "ANDROID_HOME": "/usr/local/lib/android/sdk",
    "JAVA_HOME": "/usr/lib/jvm/temurin-21-jdk"
  },
  "remoteUser": "node"
}
